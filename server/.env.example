PORT=4000
CLIENT_ORIGIN=http://localhost:5173
CONTACT_TO=your-email@example.com

# Option A: Resend (recommended on Render – no SMTP blocking). Get key at resend.com
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Portfolio Contact <onboarding@resend.dev>

# Option B: SMTP (e.g. Gmail). Often blocked on Render free tier.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password

